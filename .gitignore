# Dependencies (always reinstall with npm install)
node_modules/

# Compiled stepper binary (build on each machine: npm run build:stepper)
stepper
stepper.exe
*.o

# Local env and secrets — copy from .env.example if you use one
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
*.swp
*.swo

# Keys and certs (if you ever add them)
*.pem
*.key
*.p12
*.pfx

# Test / coverage
coverage/
.nyc_output/
